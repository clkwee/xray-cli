#!/usr/bin/env python3
"""
Xray CLI - Manage Xray proxy and TUN mode
Simple tool to manage your Xray proxy connection
"""
import argparse
import json
import os
import subprocess
import sys
import urllib.parse
import shutil
import time
import base64  # ← ADDED: for base64 subscription decoding
from pathlib import Path
from typing import Dict, Optional

# Configuration paths
CONFIG_DIR = Path.home() / ".config" / "xray-cli"
CONFIG_FILE = CONFIG_DIR / "config.json"
XRAY_CONFIG = CONFIG_DIR / "xray.json"
REDSOCKS_CONFIG = "/etc/redsocks.conf"
TUN_ENABLED_FLAG = CONFIG_DIR / "tun_enabled.flag"

# Colors for pretty output
class Colors:
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    BLUE = '\033[94m'
    END = '\033[0m'

def print_success(msg):
    print(f"{Colors.GREEN}✓ ✨{Colors.END} {msg}")

def print_info(msg):
    print(f"{Colors.BLUE}ℹ 💡{Colors.END} {msg}")

def print_warning(msg):
    print(f"{Colors.YELLOW}⚠ 🤔{Colors.END} {msg}")

def print_error(msg):
    print(f"{Colors.RED}✗ ❌{Colors.END} {msg}", file=sys.stderr)

def ensure_config_dir():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

def parse_vless_url(url: str) -> Dict[str, str]:
    """Parse vless:// URL and extract all the settings"""
    url = url.strip()  # ← FIX: Remove whitespace
    if not url.startswith("vless://"):
        raise ValueError("URL must start with vless://")
    
    url = url[8:]  # Remove vless:// prefix
    
    if "#" in url:
        url, remark = url.split("#", 1)
    
    if "?" in url:
        base, params_str = url.split("?", 1)
    else:
        base = url
        params_str = ""
    
    if "@" not in base:
        raise ValueError("Missing @ separator in URL")
    uuid, server = base.split("@", 1)
    
    # Handle IPv6 [address]:port or IPv4 address:port
    if server.startswith("["):
        if "]:" not in server:
            raise ValueError("Invalid IPv6 format")
        server_ip, port_str = server.rsplit("]:", 1)
        server_ip = server_ip[1:]
    else:
        if ":" not in server:
            raise ValueError("Missing port in URL")
        parts = server.rsplit(":", 1)
        if len(parts) != 2:
            raise ValueError("Invalid server format")
        server_ip, port_str = parts
    
    try:
        server_port = int(port_str)
    except ValueError:
        raise ValueError("Port must be a number")
    
    params = {}
    if params_str:
        for param in params_str.split("&"):
            if "=" in param:
                key, value = param.split("=", 1)
                params[key] = urllib.parse.unquote(value)
    
    return {
        "uuid": uuid,
        "server_ip": server_ip,
        "server_port": server_port,
        "security": params.get("security", "reality"),
        "pbk": params.get("pbk", ""),
        "sid": params.get("sid", ""),
        "fp": params.get("fp", "chrome"),
        "flow": params.get("flow", "xtls-rprx-vision"),
        "spx": params.get("spx", "/"),
    }

def generate_xray_config(vless_config: Dict) -> Dict:
    """Create the Xray JSON config file content"""
    return {
        "inbounds": [{
            "listen": "127.0.0.1",
            "port": 1080,
            "protocol": "socks",
            "settings": {"udp": True}
        }],
        "outbounds": [{
            "tag": "proxy",
            "protocol": "vless",
            "settings": {
                "vnext": [{
                    "address": vless_config["server_ip"],
                    "port": vless_config["server_port"],
                    "users": [{
                        "id": vless_config["uuid"],
                        "encryption": "none",
                        "flow": vless_config["flow"]
                    }]
                }]
            },
            "streamSettings": {
                "network": "tcp",
                "security": vless_config["security"],
                "realitySettings": {
                    "publicKey": vless_config["pbk"],
                    "shortId": vless_config["sid"],
                    "fingerprint": vless_config["fp"],
                    "spiderX": vless_config["spx"]
                }
            }
        }]
    }

def get_config_from_url(url: str) -> Dict:
    """Get vless:// config from URL or parse it directly — FIXED VERSION"""
    url = url.strip()
    
    # If it's already a vless:// URL, just parse it
    if url.startswith("vless://"):
        return parse_vless_url(url)
    
    print_info(f"Fetching config from {url}...")
    
    # Download content
    content = None
    try:
        import requests
        response = requests.get(
            url, 
            timeout=15, 
            headers={'User-Agent': 'Mozilla/5.0 (Xray-CLI/1.0)'},
            allow_redirects=True
        )
        response.raise_for_status()
        content = response.text.strip()
    except ImportError:
        try:
            result = subprocess.run(
                ["curl", "-sL", "--connect-timeout", "10", "-A", "Mozilla/5.0 (Xray-CLI/1.0)", url],
                capture_output=True, text=True, check=True, timeout=15
            )
            content = result.stdout.strip()
        except FileNotFoundError:
            raise RuntimeError("Neither 'requests' nor 'curl' found")
        except subprocess.CalledProcessError as e:
            raise RuntimeError(f"Download failed: {e}")
    except Exception as e:
        raise RuntimeError(f"Fetch failed: {e}")
    
    if not content:
        raise RuntimeError("Empty response from server")
    
    # ← FIX 1: Try base64 decode (most subscriptions are base64!)
    try:
        decoded = base64.b64decode(content).decode('utf-8', errors='ignore')
        if "vless://" in decoded:
            for line in decoded.split('\n'):
                line = line.strip()
                if line.startswith("vless://"):
                    print_info("✓ Found config in base64-decoded content")
                    return parse_vless_url(line)
    except:
        pass  # Not base64, continue
    
    # ← FIX 2: Handle multi-line plain text responses
    for line in content.split('\n'):
        line = line.strip()
        if line.startswith("vless://"):
            print_info("✓ Found config in response")
            return parse_vless_url(line)
    
    # ← Debug hint
    preview = content[:150].replace('\n', ' ')
    raise ValueError(f"No valid vless:// URL found. Response preview: '{preview}...'")

def save_config(config: Dict):
    ensure_config_dir()
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)
    print_success(f"Config saved to {CONFIG_FILE}")

def load_config() -> Optional[Dict]:
    if not CONFIG_FILE.exists():
        return None
    with open(CONFIG_FILE, "r") as f:
        return json.load(f)

def write_xray_config(vless_config: Dict):
    ensure_config_dir()
    xray_config = generate_xray_config(vless_config)
    with open(XRAY_CONFIG, "w") as f:
        json.dump(xray_config, f, indent=2)
    print_success(f"Xray config written to {XRAY_CONFIG}")

def check_root():
    if os.geteuid() != 0:
        print_error("This command needs root privileges")
        print_info("Run with: sudo xray-cli ...")
        sys.exit(1)

def find_executable(name: str) -> Optional[str]:
    return shutil.which(name)

def is_xray_running() -> bool:
    result = subprocess.run(["pgrep", "-x", "xray"], capture_output=True)
    if result.returncode != 0:
        return False
    result = subprocess.run(["ps", "aux"], capture_output=True, text=True)
    return str(XRAY_CONFIG) in result.stdout

def is_redsocks_running() -> bool:
    return subprocess.run(["pgrep", "redsocks"], capture_output=True).returncode == 0

def is_tun_enabled() -> bool:
    return subprocess.run(
        ["iptables", "-t", "nat", "-L", "REDSOCKS"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    ).returncode == 0

def is_autostart_enabled() -> bool:
    service_file = Path("/etc/systemd/system/xray-cli-proxy.service")
    if not service_file.exists():
        return False
    result = subprocess.run(
        ["systemctl", "is-enabled", "xray-cli-proxy.service"],
        capture_output=True, text=True
    )
    return result.stdout.strip() == "enabled"

def enable_autostart():
    check_root()
    config = load_config()
    if not config:
        print_error("No config found! Set up config first.")
        print_info("Run: xray-cli get-config <vless-url>")
        return
    
    print_info("Creating systemd service for autostart... 📝")
    service_content = f"""[Unit]
Description=Xray CLI Proxy Service
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/xray-cli proxy start
ExecStop=/usr/local/bin/xray-cli proxy stop

[Install]
WantedBy=multi-user.target
"""
    service_file = Path("/etc/systemd/system/xray-cli-proxy.service")
    try:
        with open(service_file, "w") as f:
            f.write(service_content)
        print_success(f"Autostart service file created: {service_file}")
        subprocess.run(["systemctl", "daemon-reload"], check=True)
        subprocess.run(["systemctl", "enable", "xray-cli-proxy.service"], check=True)
        print_success("Autostart enabled! 🎉")
    except Exception as e:
        print_error(f"Failed to enable autostart: {e}")

def disable_autostart():
    check_root()
    service_file = Path("/etc/systemd/system/xray-cli-proxy.service")
    if not service_file.exists():
        print_info("Autostart is not enabled")
        return
    try:
        subprocess.run(["systemctl", "disable", "xray-cli-proxy.service"], check=True)
        subprocess.run(["systemctl", "stop", "xray-cli-proxy.service"],
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        service_file.unlink()
        subprocess.run(["systemctl", "daemon-reload"], check=True)
        print_success("Autostart disabled! 🛑")
    except Exception as e:
        print_error(f"Failed to disable autostart: {e}")

def install_everything():
    check_root()
    print_info("Starting auto-installation... 📦")
    
    os_release = Path("/etc/os-release").read_text()
    if "ubuntu" in os_release or "debian" in os_release:
        pkg_manager, redsocks_pkg = "apt", "redsocks"
    elif "arch" in os_release or "manjaro" in os_release:
        pkg_manager, redsocks_pkg = "pacman", "redsocks"
    else:
        print_error("Unsupported distribution")
        return
    
    print_info(f"Installing Redsocks via {pkg_manager}...")
    try:
        if pkg_manager == "apt":
            subprocess.run(["apt", "update"], check=True)
            subprocess.run(["apt", "install", "-y", redsocks_pkg], check=True)
        else:
            subprocess.run(["pacman", "-Sy", "--noconfirm", redsocks_pkg], check=True)
        print_success("Redsocks installed! ✅")
    except Exception as e:
        print_error(f"Redsocks install failed: {e}")
        return
    
    print_info("Installing Xray...")
    try:
        subprocess.run([
            "bash", "-c", 'curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh | bash'
        ], check=True)
        print_success("Xray installed! ✅")
    except Exception as e:
        print_error(f"Xray install failed: {e}")
        return
    
    redsocks_config = """base {
    log_debug = on;
    log_info = on;
    log = "file:/var/log/redsocks.log";
    daemon = on;
    redirector = iptables;
}
redsocks {
    local_ip = 127.0.0.1;
    local_port = 2525;
    ip = 127.0.0.1;
    port = 1080;
    type = socks5;
}
"""
    try:
        Path(REDSOCKS_CONFIG).parent.mkdir(parents=True, exist_ok=True)
        with open(REDSOCKS_CONFIG, "w") as f:
            f.write(redsocks_config)
        print_success(f"Redsocks config written to {REDSOCKS_CONFIG} ✅")
    except IOError as e:
        print_error(f"Failed to write Redsocks config: {e}")

def show_status():
    print("=" * 50)
    print("🔍 Xray CLI Status")
    print("=" * 50)
    config = load_config()
    if config:
        print_success(f"Config: {config['server_ip']}:{config['server_port']}")
    else:
        print_warning("No config found")
    
    print_success("Xray: Running 🚀") if is_xray_running() else print_warning("Xray: Stopped 💤")
    print_success("Redsocks: Running 🔄") if is_redsocks_running() else print_info("Redsocks: Stopped 💤")
    print_success("TUN: Enabled 🛡️") if is_tun_enabled() else print_info("TUN: Disabled 🔓")
    print_success("Autostart: On 🔄") if is_autostart_enabled() else print_info("Autostart: Off")
    print("=" * 50)

def start_tun_logic():
    redsocks_path = find_executable("redsocks")
    if not redsocks_path:
        raise RuntimeError("Redsocks not found!")
    if not Path(REDSOCKS_CONFIG).exists():
        raise RuntimeError(f"Redsocks config not found at {REDSOCKS_CONFIG}")
    
    if not is_redsocks_running():
        subprocess.Popen([redsocks_path, "-c", REDSOCKS_CONFIG])
        print_info("Redsocks started 🔄")
        time.sleep(1)
    
    # Clean old rules
    for cmd in [
        ["iptables", "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "-m", "owner", "!", "--uid-owner", "root", "-j", "REDSOCKS"],
        ["iptables", "-t", "nat", "-F", "REDSOCKS"],
        ["iptables", "-t", "nat", "-X", "REDSOCKS"]
    ]:
        subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # Set new rules
    subprocess.run(["iptables", "-t", "nat", "-N", "REDSOCKS"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["iptables", "-t", "nat", "-A", "REDSOCKS", "-d", "127.0.0.0/8", "-j", "RETURN"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["iptables", "-t", "nat", "-A", "REDSOCKS", "-p", "tcp", "-j", "REDIRECT", "--to-ports", "2525"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["iptables", "-t", "nat", "-A", "OUTPUT", "-p", "tcp", "-m", "owner", "!", "--uid-owner", "root", "-j", "REDSOCKS"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    print_success("TUN mode enabled! 🛡️")
    TUN_ENABLED_FLAG.touch(exist_ok=True)

def start_proxy():
    check_root()
    config = load_config()
    if not config:
        print_error("No config found! Run: xray-cli get-config <url>")
        sys.exit(1)
    
    xray_path = find_executable("xray")
    if not xray_path:
        print_error("Xray not found! Install with: sudo xray-cli install-everything")
        sys.exit(1)
    
    if is_xray_running():
        print_warning("Xray already running!")
        return
    
    write_xray_config(config)
    subprocess.Popen([xray_path, "run", "-c", str(XRAY_CONFIG)],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    time.sleep(1)
    
    if is_xray_running():
        print_success("Xray started! 🎉 SOCKS5 on 127.0.0.1:1080")
        if TUN_ENABLED_FLAG.exists():
            print_info("TUN flag found, attempting to enable TUN...")
            try:
                start_tun_logic()
            except Exception as e:
                print_error(f"TUN start failed: {e}")
    else:
        print_error("Failed to start Xray")
        sys.exit(1)

def stop_proxy():
    check_root()
    if not is_xray_running():
        print_info("Xray not running")
        return
    if subprocess.run(["pkill", "xray"], capture_output=True).returncode == 0:
        print_success("Xray stopped 🛑")
    else:
        print_warning("Failed to stop Xray")

def start_tun():
    check_root()
    if not is_xray_running():
        print_warning("Xray not running, starting first...")
        start_proxy()
        time.sleep(1)
    start_tun_logic()

def stop_tun():
    check_root()
    for cmd in [
        ["iptables", "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "-m", "owner", "!", "--uid-owner", "root", "-j", "REDSOCKS"],
        ["iptables", "-t", "nat", "-F", "REDSOCKS"],
        ["iptables", "-t", "nat", "-X", "REDSOCKS"]
    ]:
        subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if is_redsocks_running():
        subprocess.run(["pkill", "redsocks"], capture_output=True)
        print_success("Redsocks stopped 🛑")
    print_success("TUN mode disabled 🔓")
    if TUN_ENABLED_FLAG.exists():
        TUN_ENABLED_FLAG.unlink()

def kill_everything():
    check_root()
    print_warning("Killing everything... 🗡️")
    
    # Stop service
    svc = Path("/etc/systemd/system/xray-cli-proxy.service")
    if svc.exists():
        subprocess.run(["systemctl", "stop", "xray-cli-proxy.service"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["systemctl", "disable", "xray-cli-proxy.service"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        svc.unlink()
        subprocess.run(["systemctl", "daemon-reload"], check=False)
    
    # Kill processes
    for proc in ["xray", "redsocks"]:
        subprocess.run(["pkill", "-f", proc], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(0.3)
        pids = subprocess.run(["pgrep", "-f", proc], capture_output=True, text=True).stdout.strip()
        if pids:
            subprocess.run(["kill", "-9"] + pids.split(), stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # Flush iptables
    for cmd in [
        ["iptables", "-t", "nat", "-F", "REDSOCKS"],
        ["iptables", "-t", "nat", "-X", "REDSOCKS"],
        ["iptables", "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "-m", "owner", "!", "--uid-owner", "root", "-j", "REDSOCKS"]
    ]:
        subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # Stop default xray.service if exists
    if subprocess.run(["systemctl", "is-active", "--quiet", "xray.service"]).returncode == 0:
        subprocess.run(["systemctl", "stop", "xray.service"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if subprocess.run(["systemctl", "is-enabled", "--quiet", "xray.service"]).returncode == 0:
        subprocess.run(["systemctl", "disable", "xray.service"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    print_success("Everything killed! 🧹✨")

def run_app(app_name: str, *args):
    config = load_config()
    if not config:
        print_error("No config found!")
        sys.exit(1)
    if not is_xray_running():
        print_warning("Xray not running, starting...")
        if os.geteuid() != 0:
            print_error("Need root to start Xray")
            sys.exit(1)
        start_proxy()
        time.sleep(1)
    
    app_path = find_executable(app_name)
    if not app_path:
        print_error(f"{app_name} not found!")
        sys.exit(1)
    
    env = os.environ.copy()
    env["http_proxy"] = env["https_proxy"] = env["ALL_PROXY"] = "socks5://127.0.0.1:1080"
    print_info(f"Launching {app_name} with proxy... 🚀")
    
    if any(b in app_name.lower() for b in ["chromium", "chrome", "brave"]):
        subprocess.run([app_path, f"--proxy-server=socks5://127.0.0.1:1080", *args], env=env)
    else:
        subprocess.run([app_path, *args], env=env)

def interactive_menu():
    while True:
        print("\033[2J\033[H", end="")
        print("=" * 50 + "\n🔍 Xray CLI - Interactive Menu\n" + "=" * 50 + "\n")
        
        config = load_config()
        if config:
            print_info(f"Config: {config['server_ip']}:{config['server_port']}")
        else:
            print_warning("No config found")
        
        print_success("Proxy: Running 🚀") if is_xray_running() else print_info("Proxy: Stopped 💤")
        print_success("TUN: Enabled 🛡️") if is_tun_enabled() else print_info("TUN: Disabled 🔓")
        print_success("Autostart: On 🔄") if is_autostart_enabled() else print_info("Autostart: Off")
        
        print(f"\n{'='*50}\n📋 Menu Options:\n{'='*50}\n")
        print("  1. 📊 Show Status\n  2. 🚀 Start Proxy\n  3. 🛑 Stop Proxy\n  4. 🛡️  Enable TUN\n  5. 🔓 Disable TUN")
        print("  6. 📥 Get/Update Config\n  7. 🏃 Run App with Proxy\n  8. 🔄 Restart Proxy")
        print("  9. 🔁 Enable Autostart\n 10. 🚫 Disable Autostart\n 11. 📦 Install Everything\n 12. 🗡️  Kill Everything\n 13. ❌ Exit\n")
        
        try:
            choice = input("💡 Choose option (1-13): ").strip()
            print()
            
            if choice == "1": show_status(); input("\n✓ Press Enter...")
            elif choice == "2":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: start_proxy(); input("\n✓ Press Enter...")
            elif choice == "3":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: stop_proxy(); input("\n✓ Press Enter...")
            elif choice == "4":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: start_tun(); input("\n✓ Press Enter...")
            elif choice == "5":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: stop_tun(); input("\n✓ Press Enter...")
            elif choice == "6":
                url = input("📥 Enter vless:// URL or subscription link: ").strip()
                if url:
                    try:
                        config = get_config_from_url(url.strip())
                        save_config(config)
                        print_success("Config saved! 🎉")
                        print_info(f"Server: {config['server_ip']}:{config['server_port']}")
                    except Exception as e:
                        print_error(f"Failed: {e}")
                    input("\n✓ Press Enter...")
            elif choice == "7":
                app = input("🏃 App name: ").strip()
                if app:
                    args_in = input("⚙️  Extra args (or Enter): ").strip()
                    try: run_app(app, *(args_in.split() if args_in else []))
                    except Exception as e: print_error(f"Failed: {e}")
                    input("\n✓ Press Enter...")
            elif choice == "8":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: print_info("Restarting... 🔄"); stop_proxy(); time.sleep(1); start_proxy(); input("\n✓ Press Enter...")
            elif choice == "9":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: enable_autostart(); input("\n✓ Press Enter...")
            elif choice == "10":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: disable_autostart(); input("\n✓ Press Enter...")
            elif choice == "11":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: install_everything(); input("\n✓ Press Enter...")
            elif choice == "12":
                if os.geteuid() != 0: print_warning("Need root"); input("\n✓ Press Enter...")
                else: kill_everything(); input("\n✓ Press Enter...")
            elif choice == "13": print_success("Goodbye! 👋"); break
            else: print_warning("Invalid option"); input("\n✓ Press Enter...")
        except KeyboardInterrupt:
            print("\n"); print_success("Goodbye! 👋"); break
        except Exception as e:
            print_error(f"Error: {e}"); input("\n✓ Press Enter...")

def main():
    parser = argparse.ArgumentParser(description="Xray CLI - Easy proxy management")
    subs = parser.add_subparsers(dest="command")
    
    subs.add_parser("install-everything", help="Auto-install Xray + Redsocks")
    gc = subs.add_parser("get-config", help="Download vless config"); gc.add_argument("url")
    subs.add_parser("status", help="Show status")
    
    px = subs.add_parser("proxy", help="Control proxy"); pxs = px.add_subparsers(dest="proxy_action")
    pxs.add_parser("start"); pxs.add_parser("stop"); pxs.add_parser("restart")
    
    tn = subs.add_parser("tun", help="Control TUN mode"); tns = tn.add_subparsers(dest="tun_action")
    tns.add_parser("start"); tns.add_parser("stop")
    
    au = subs.add_parser("autostart", help="Manage boot startup"); aus = au.add_subparsers(dest="autostart_action")
    aus.add_parser("enable"); aus.add_parser("disable"); aus.add_parser("status")
    
    subs.add_parser("kill-everything", help="Kill all processes + flush rules")
    
    rp = subs.add_parser("run", help="Run app with proxy"); rp.add_argument("app"); rp.add_argument("args", nargs=argparse.REMAINDER)
    
    args = parser.parse_args()
    if not args.command: interactive_menu(); return
    
    try:
        if args.command == "install-everything": install_everything()
        elif args.command == "get-config":
            config = get_config_from_url(args.url.strip())  # ← FIX: .strip()
            save_config(config)
            print_success("Config saved! 🎉")
            print_info(f"Server: {config['server_ip']}:{config['server_port']}")
        elif args.command == "status": show_status()
        elif args.command == "proxy":
            if args.proxy_action == "start": start_proxy()
            elif args.proxy_action == "stop": stop_proxy()
            elif args.proxy_action == "restart": check_root(); stop_proxy(); time.sleep(1); start_proxy()
            else: px.print_help()
        elif args.command == "tun":
            if args.tun_action == "start": start_tun()
            elif args.tun_action == "stop": stop_tun()
            else: tn.print_help()
        elif args.command == "autostart":
            if args.autostart_action == "enable": enable_autostart()
            elif args.autostart_action == "disable": disable_autostart()
            elif args.autostart_action == "status":
                print_success("Autostart: Enabled 🔄") if is_autostart_enabled() else print_info("Autostart: Disabled")
            else: au.print_help()
        elif args.command == "kill-everything": kill_everything()
        elif args.command == "run": run_app(args.app, *args.args)
    except KeyboardInterrupt: print("\nCancelled"); sys.exit(0)
    except Exception as e: print_error(f"{e}"); sys.exit(1)

if __name__ == "__main__":
    main()
